// Component Example
( MyComp
    str: "top text"
    components: {
      p1: ( MyComp
              str: "p1 text file1"
              components: {
                z1: (MyComp str: "z1 text" )
              }
          )
      p2: ( MyComp str: "p2 text file1" )
      p3: ( MyComp str: "p3 text file1" )
      p4: ( MyComp str: "p4 text file1" )
    }
)
